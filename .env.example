# Server port
PORT=1234

# SQLite database path
DATABASE_URL=file:./data/chat.db

# Application secret (for session signing, optional)
APP_SECRET=

# Authentication secret (optional)
AUTH_SECRET=

# Admin password (optional)
ADMIN_PASSWORD=

# Default provider ID (optional, UUID of a provider profile)
DEFAULT_PROVIDER_ID=

# Tool runtime mode: "node" or "docker"
TOOL_RUNTIME_MODE=node
